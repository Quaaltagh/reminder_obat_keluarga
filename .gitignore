# ==========================================
# Tambahan untuk project Care Circle
# ==========================================

# --- Code generation (Drift, Riverpod, Freezed) ---
# Tiap developer generate ulang lokal via `dart run build_runner build`
# supaya tidak ada konflik merge di file hasil generate
**/*.g.dart
**/*.freezed.dart
**/*.drift.dart

# --- Firebase & credentials ---
# Tiap developer sebaiknya jalankan `flutterfire configure` sendiri
# supaya tidak bentrok / accidental overwrite config Firebase orang lain.
# Kalau nanti sepakat mau share 1 config yang sama, baris ini boleh dihapus.
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
lib/firebase_options.dart

# --- Android signing (untuk build APK release nanti) ---
android/key.properties
android/app/upload-keystore.jks
*.jks
*.keystore

# --- Environment variables / API keys (kalau nanti pakai .env) ---
.env
.env.local
*.env

# --- Local database (Drift/SQLite) hasil development ---
*.sqlite
*.sqlite-journal
*.db

# --- OS files tambahan ---
Thumbs.db
desktop.ini